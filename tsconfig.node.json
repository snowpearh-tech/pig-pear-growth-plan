{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "baseUrl": ".",
    "paths": {
      "@shared/*": ["shared/*"]
    },
    "types": ["node", "@cloudflare/workers-types"]
  },
  "include": [
    "vite.config.ts",
    "tailwind.config.ts",
    "functions/**/*.ts",
    "shared/**/*.ts"
  ]
}
